---
// src/components/ProjectCard.astro
// Karta projektu s cover obrázkem nebo ilustračním placeholderem.
// Bez fotky se zobrazí tónová plocha s ilustrací sekce — všechny
// karty v řádku mají stejnou výšku díky aspect-ratio + flexbox.
//
// Ilustrace se vybere takto (sestupná priorita):
//  1. frontmatter pole `illustration: "tree-rings"` (stem, bez cesty a .svg)
//  2. prop `cardIndex` — rotace přes seznam ilustrací sekce
//  3. první ilustrace dané sekce

interface Props {
  title: string;
  description?: string;
  tone?: 'coral' | 'gold' | 'mint' | 'blue';
  tag?: string;
  href?: string;
  /** URL fotky. Když chybí, zobrazí se ilustrace sekce. */
  image?: string;
  /**
   * Stem ilustrace z frontmatteru (např. "tree-rings").
   * Přepíše automatickou rotaci.
   */
  illustration?: string;
  /** Pořadí karty v sekci — pro automatickou rotaci ilustrací. */
  cardIndex?: number;
  /** Datum ve formátu YYYY-MM — zobrazí se jako štítek vedle tagu. */
  date?: string;
}

// Dostupné ilustrace per tón (stem → full public path)
const ILLUSTRATIONS: Record<string, string[]> = {
  coral: ['double-diamond','journey-map','postits','people-circle','magnifier','layers','venn'],
  gold:  ['tree-rings','square-pencil','tools','playground','wood-joint'],
  mint:  ['bicycle','glass','network','campfire','hands'],
  blue:  ['loop','book','flow-diagram','timeline'],
};

// Složky per tón
const TONE_DIR: Record<string, string> = {
  coral: 'hlavou',
  gold:  'rukama',
  mint:  'komunitne',
  blue:  'studium',
};

const {
  title, description,
  tone = 'coral',
  tag, href = '#',
  image,
  illustration,
  cardIndex = 0,
  date,
} = Astro.props;

function resolveIll(tone: string, stem?: string, idx: number = 0): string {
  const dir   = TONE_DIR[tone];
  const set   = ILLUSTRATIONS[tone];
  const chosen = stem && set.includes(stem) ? stem : set[idx % set.length];
  return `/illustrations/${dir}/${chosen}.svg`;
}

const illSrc = image ? '' : resolveIll(tone, illustration, cardIndex);
---

<a href={href} class:list={['card', `card--${tone}`]}>
  {image
    ? <div class="cover" style={`background-image: url(${image})`}></div>
    : <div class="placeholder">
        <img src={illSrc} alt="" class="ill" />
      </div>
  }
  <div class="content">
    <div class="meta-row">
      {tag && <span class:list={['tag', `tag--${tone}`]}>{tag}</span>}
      {date && <span class="date-pill">{date}</span>}
    </div>
    <h3>{title}</h3>
    {description && <p>{description}</p>}
    <span class="more">Číst více →</span>
  </div>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    height: 100%;            /* stretch in CSS grid */
    text-decoration: none;
    background: var(--surface-2);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition:
      transform var(--dur-base) var(--ease),
      box-shadow var(--dur-base) var(--ease);
  }
  .card:hover {
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }

  /* Cover photo */
  .cover {
    aspect-ratio: 16 / 10;
    background-size: cover;
    background-position: center;
    flex-shrink: 0;
  }

  /* Illustration placeholder — same 16:10 area */
  .placeholder {
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .card--coral .placeholder { background: var(--coral-bg); }
  .card--gold  .placeholder { background: var(--gold-bg);  }
  .card--mint  .placeholder { background: var(--mint-bg);  }
  .card--blue  .placeholder { background: var(--blue-bg);  }
  .ill { width: 50%; height: 50%; object-fit: contain; opacity: 0.72; }

  /* Body */
  .content {
    padding: 16px;
    display: flex;
    flex-direction: column;
    flex: 1;
    gap: 6px;
  }

  /* Tag */
  .tag {
    display: inline-block;
    font-size: var(--text-2xs);
    font-weight: var(--weight-medium);
    border-radius: var(--r-pill);
    padding: 3px 10px;
    align-self: flex-start;
  }
  .tag--coral { background: var(--coral-bg); color: var(--coral-text); }
  .tag--gold  { background: var(--gold-bg);  color: var(--gold-text);  }
  .tag--mint  { background: var(--mint-bg);  color: var(--mint-text);  }
  .tag--blue  { background: var(--blue-bg);  color: var(--blue-text);  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .date-pill {
    display: inline-block;
    font-size: var(--text-2xs);
    font-weight: var(--weight-medium);
    border-radius: var(--r-pill);
    padding: 3px 10px;
    background: var(--surface);
    color: var(--muted);
    margin-left: auto;
  }

  h3 { font-size: var(--text-h3); font-weight: var(--weight-medium); color: var(--text); margin: 0; }
  p  { color: var(--muted); font-size: var(--text-sm); line-height: 1.6; margin: 0; max-width: 38ch; }

  /* "Číst více →" — slides in on hover */
  .more {
    font-size: var(--text-xs);
    color: var(--muted);
    margin-top: auto;
    padding-top: 10px;
    opacity: 0;
    transform: translateX(-4px);
    transition:
      opacity var(--dur-base) var(--ease),
      transform var(--dur-base) var(--ease);
  }
  .card:hover .more {
    opacity: 1;
    transform: translateX(0);
  }
</style>
