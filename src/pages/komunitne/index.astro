---
// src/pages/komunitne/index.astro
import { getCollection, getEntry, render } from 'astro:content';
import SectionIndex from '../../layouts/SectionIndex.astro';

const entries = await getCollection('komunitne', ({ data }) => !data.draft);
const introEntry = await getEntry('intros', 'komunitne');
const home = (await getEntry('intros', 'home'))!.data as Record<string, string>;
const { Content: Intro } = await render(introEntry!);
---

<SectionIndex
  eyebrow="Komunitně"
  title={home.komunitne_title}
  tone="mint"
  world="komunitne"
  entries={entries}
>
  <div slot="intro">
    <Intro />
  </div>
</SectionIndex>
