---
// src/pages/hlavou/index.astro
import { getCollection, getEntry, render } from 'astro:content';
import SectionIndex from '../../layouts/SectionIndex.astro';

const entries = await getCollection('hlavou', ({ data }) => !data.draft);
const introEntry = await getEntry('intros', 'hlavou');
const home = (await getEntry('intros', 'home'))!.data as Record<string, string>;
const { Content: Intro } = await render(introEntry!);
---

<SectionIndex
  eyebrow="Hlavou"
  title={home.hlavou_title}
  tone="coral"
  world="hlavou"
  entries={entries}
>
  <div slot="intro">
    <Intro />
  </div>
</SectionIndex>
