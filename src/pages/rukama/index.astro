---
// src/pages/rukama/index.astro
import { getCollection, getEntry, render } from 'astro:content';
import SectionIndex from '../../layouts/SectionIndex.astro';

const entries = await getCollection('rukama', ({ data }) => !data.draft);
const introEntry = await getEntry('intros', 'rukama');
const home = (await getEntry('intros', 'home'))!.data as Record<string, string>;
const { Content: Intro } = await render(introEntry!);
---

<SectionIndex
  eyebrow="Rukama"
  title={home.rukama_title}
  tone="gold"
  world="rukama"
  entries={entries}
>
  <div slot="intro">
    <Intro />
  </div>
</SectionIndex>
