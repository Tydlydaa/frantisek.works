---
// src/pages/prezentace.astro
// Jednorázová / neveřejná stránka pro prezentaci — proklikávání přes vybrané projekty.
// Nikde v navigaci, ale dostupná na /prezentace.
//
// Jak upravit výběr: přidej/odeber/přeřaď položky v poli ITEMS níže.
// collection: 'hlavou' | 'rukama' | 'komunitne' | 'studium'
// slug: název .md souboru bez přípony (např. 'partyzanska-stezka')

import Layout from '../layouts/Layout.astro';
import { getEntry, render } from 'astro:content';

const ITEMS: { collection: 'hlavou' | 'rukama' | 'komunitne' | 'studium'; slug: string }[] = [
  { collection: 'studium', slug: 'co-moje-studijni-cile' },
  { collection: 'studium', slug: 'design-hackathon-bankovni-podvody' },
  { collection: 'studium', slug: 'jak-jsme-rozsirili-vyzkum-o-bariery' },
  { collection: 'studium', slug: 'jak-jsme-s-drymtymem-skoro-nic-neudelali' },
  { collection: 'studium', slug: 'reflexe-praxe-iv-workshop-pro-tajemniky' },
  { collection: 'studium', slug: 'camp-cx-blueprint' },
  { collection: 'studium', slug: 'partyzanska-stezka' },
  { collection: 'studium', slug: 'test-pristupnosti-dvorek' },
  { collection: 'studium', slug: 'kod-ve-vytahu' },
  { collection: 'studium', slug: 'rozjezd-truhlarskeho-studia' },
  { collection: 'studium', slug: 'reflexe-posledniho-vi-semestru' },
  { collection: 'studium', slug: 'bydlo-prezentace' },
  { collection: 'studium', slug: 'co-moje-studijni-cile' },
];

const slides = await Promise.all(
  ITEMS.map(async ({ collection, slug }) => {
    const entry = await getEntry(collection, slug);
    if (!entry) throw new Error(`Entry not found: ${collection}/${slug}`);
    const { Content } = await render(entry);
    return { data: entry.data, Content };
  })
);
---

<Layout title="Prezentace — František Pfann">
  <div class="presenter">

    <div class="bar">
      <span class="counter"><span id="current">1</span> / {slides.length}</span>
      <div class="nav-buttons">
        <button id="prev" aria-label="Předchozí">←</button>
        <button id="next" aria-label="Další">→</button>
      </div>
    </div>

    {slides.map((slide, i) => (
      <article class="slide" data-index={i}>
        {slide.data.image && (
          <div class="cover" style={`background-image: url(${slide.data.image})`} role="img" aria-label={slide.data.title} />
        )}
        <header class="slide-header">
          <span class="tag">{slide.data.tag}</span>
          <h1>{slide.data.title}</h1>
          <p class="lead">{slide.data.description}</p>
        </header>
        <div class="prose">
          <slide.Content />
        </div>
      </article>
    ))}

  </div>
</Layout>

<style>
  .presenter {
    padding: var(--space-lg) 0 calc(var(--space-xl) * 1.5);
    max-width: 700px;
  }

  .bar {
    position: sticky;
    top: 0;
    display: flex;
    align-items: center;
    justify-content: space-between;
    background: var(--bg);
    padding: var(--space-sm) 0;
    margin-bottom: var(--space-lg);
    border-bottom: 0.5px solid var(--border);
    z-index: 10;
  }
  .counter { font-size: var(--text-sm); color: var(--muted); }
  .nav-buttons { display: flex; gap: 8px; }
  .nav-buttons button {
    font-family: var(--font);
    font-size: var(--text-md);
    width: 40px;
    height: 40px;
    border-radius: var(--r-pill);
    border: 1.5px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    transition: all 0.15s;
  }
  .nav-buttons button:hover { border-color: var(--text); }
  .nav-buttons button:disabled { opacity: 0.3; cursor: default; }

  .slide { display: none; }
  .slide.active { display: block; }

  .cover {
    aspect-ratio: 16 / 9;
    border-radius: var(--r-lg);
    background-size: contain;
    background-position: top center;
    background-repeat: no-repeat;
    margin-bottom: var(--space-lg);
    background-color: var(--surface);
  }

  .slide-header { margin-bottom: var(--space-lg); }
  .tag {
    display: inline-block;
    font-size: var(--text-2xs);
    font-weight: var(--weight-medium);
    border-radius: var(--r-pill);
    padding: 3px 10px;
    background: var(--surface);
    color: var(--muted);
    margin-bottom: 10px;
  }
  h1 {
    font-size: var(--text-display);
    font-weight: var(--weight-medium);
    line-height: var(--lh-tight);
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    color: var(--text);
  }
  .lead {
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--text);
    max-width: 52ch;
    margin: 0;
  }

  .prose {
    line-height: var(--lh);
    color: var(--muted);
    border-top: 0.5px solid var(--border);
    padding-top: var(--space-lg);
    margin-top: var(--space-lg);
  }
  .prose :global(h2) {
    font-size: var(--text-h2);
    font-weight: var(--weight-medium);
    color: var(--text);
    margin: var(--space-lg) 0 var(--space-sm);
    line-height: var(--lh-snug);
  }
  .prose :global(h3) {
    font-size: var(--text-h3);
    font-weight: var(--weight-medium);
    color: var(--text);
    margin: var(--space-md) 0 var(--space-xs);
  }
  .prose :global(p)  { margin-bottom: var(--space-md); max-width: 65ch; }
  .prose :global(ul),
  .prose :global(ol) { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
  .prose :global(li) { margin-bottom: var(--space-xs); }
  .prose :global(a)  { color: var(--text); text-underline-offset: 3px; }
  .prose :global(strong) { color: var(--text); font-weight: var(--weight-medium); }
  .prose :global(img) { max-width: 100%; border-radius: var(--r-sm, 8px); }
  .prose :global(.image-row) {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .prose :global(.image-row) :global(p) { flex: 1 1 0; min-width: 0; margin: 0; }
  .prose :global(.image-row) :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-sm, 8px);
    margin: 0;
  }
  @media (max-width: 640px) {
    .prose :global(.image-row) { flex-direction: column; }
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--border);
    margin: var(--space-md) 0;
    padding: var(--space-xs) var(--space-md);
    color: var(--muted);
    font-style: italic;
  }

  @media (max-width: 640px) {
    h1 { font-size: clamp(1.6rem, 7vw, 2.2rem); }
    .lead { font-size: 1rem; }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.slide');
  const prevBtn = document.getElementById('prev') as HTMLButtonElement;
  const nextBtn = document.getElementById('next') as HTMLButtonElement;
  const counter = document.getElementById('current')!;

  let index = 0;

  function render() {
    slides.forEach((s, i) => s.classList.toggle('active', i === index));
    counter.textContent = String(index + 1);
    prevBtn.disabled = index === 0;
    nextBtn.disabled = index === slides.length - 1;
    window.scrollTo({ top: 0, behavior: 'instant' as ScrollBehavior });
  }

  prevBtn.addEventListener('click', () => { if (index > 0) { index--; render(); } });
  nextBtn.addEventListener('click', () => { if (index < slides.length - 1) { index++; render(); } });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowRight') nextBtn.click();
    if (e.key === 'ArrowLeft') prevBtn.click();
  });

  render();
</script>
