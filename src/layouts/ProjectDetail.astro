---
// src/layouts/ProjectDetail.astro
// Sdílený layout pro detail stránky projektu.
// Každá world sekce má vlastní [slug].astro která sem volá.

import Layout from './Layout.astro';
import Tag from '../components/Tag.astro';
import Button from '../components/Button.astro';

interface Props {
  entry: {
    data: {
      title: string;
      description: string;
      tag: string;
      tone: 'coral' | 'gold' | 'mint' | 'blue';
      image?: string;
      date?: string;
    };
    slug: string;
  };
  backHref: string;
  backLabel: string;
}

const { entry, backHref, backLabel } = Astro.props;
const { title, description, tag, tone, image, date } = entry.data;
---

<Layout title={title}>
  <article class="detail">

    <nav class="breadcrumb">
      <a href={backHref}>← {backLabel}</a>
    </nav>

    {image && (
      <div
        class="cover"
        style={`background-image: url(${image})`}
        role="img"
        aria-label={title}
      />
    )}

    <header class="detail-header">
      <div class="meta">
        <Tag tone={tone}>{tag}</Tag>
        {date && <span class="date">{date}</span>}
      </div>
      <h1>{title}</h1>
      <p class="lead">{description}</p>
    </header>

    <div class="prose">
      <slot />
    </div>

    <footer class="detail-footer">
      <Button href={backHref} variant="ghost">← Zpět</Button>
    </footer>

  </article>
</Layout>

<style>
  .detail {
    padding: var(--space-xl) 0 calc(var(--space-xl) * 1.5);
    max-width: 700px;
  }

  /* Breadcrumb */
  .breadcrumb { margin-bottom: var(--space-lg); }
  .breadcrumb a {
    font-size: var(--text-sm);
    color: var(--muted);
    text-decoration: none;
    opacity: 0.8;
    transition: opacity var(--dur-fast) var(--ease);
  }
  .breadcrumb a:hover { opacity: 1; }

  /* Cover image */
  .cover {
    aspect-ratio: 16 / 9;
    border-radius: var(--r-lg);
    background-size: cover;
    background-position: center;
    margin-bottom: var(--space-lg);
    background-color: var(--surface);
  }

  /* Header */
  .detail-header { margin-bottom: var(--space-lg); }
  .meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin-bottom: 14px;
  }
  .date {
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: 0.03em;
  }
  h1 {
    font-size: var(--text-display);
    font-weight: var(--weight-medium);
    line-height: var(--lh-tight);
    letter-spacing: -0.01em;
    margin: 0 0 16px;
    color: var(--text);
  }
  .lead {
    font-size: var(--text-lg);
    line-height: 1.55;
    color: var(--text);
    max-width: 52ch;
    margin: 0;
  }

  /* Prose */
  .prose {
    line-height: var(--lh);
    color: var(--muted);
    border-top: 0.5px solid var(--border);
    padding-top: var(--space-lg);
    margin-top: var(--space-lg);
  }
  .prose :global(h2) {
    font-size: var(--text-h2);
    font-weight: var(--weight-medium);
    color: var(--text);
    margin: var(--space-lg) 0 var(--space-sm);
    line-height: var(--lh-snug);
  }
  .prose :global(h3) {
    font-size: var(--text-h3);
    font-weight: var(--weight-medium);
    color: var(--text);
    margin: var(--space-md) 0 var(--space-xs);
  }
  .prose :global(p)  { margin-bottom: var(--space-md); max-width: 65ch; }
  .prose :global(ul),
  .prose :global(ol) { padding-left: var(--space-lg); margin-bottom: var(--space-md); }
  .prose :global(li) { margin-bottom: var(--space-xs); }
  .prose :global(a)  { color: var(--text); text-underline-offset: 3px; }
  .prose :global(strong) { color: var(--text); font-weight: var(--weight-medium); }
  .prose :global(.image-row) {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-md);
  }
  .prose :global(.image-row) :global(p) {
    flex: 1 1 0;
    min-width: 0;
    margin: 0;
  }
  .prose :global(.image-row) :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: var(--r-sm, 8px);
    margin: 0;
  }
  @media (max-width: 640px) {
    .prose :global(.image-row) {
      flex-direction: column;
    }
  }
  .prose :global(blockquote) {
    border-left: 3px solid var(--border);
    margin: var(--space-md) 0;
    padding: var(--space-xs) var(--space-md);
    color: var(--muted);
    font-style: italic;
  }

  /* Footer */
  .detail-footer { margin-top: var(--space-xl); }

  /* Mobile */
  @media (max-width: 640px) {
    h1 { font-size: clamp(1.6rem, 7vw, 2.2rem); }
    .lead { font-size: 1rem; }
  }
</style>
